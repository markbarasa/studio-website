generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Booking {
  id        String   @id @default(cuid())
  name      String
  phone     String
  service   String
  package   String
  price     Int
  date      String
  message   String?
  createdAt DateTime @default(now())
}